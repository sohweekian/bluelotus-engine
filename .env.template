# BlueLotus V3 Research Edition — copy to .env and set BLUELOTUS_PROJECT_ROOT
BLUELOTUS_PROJECT_ROOT={WORKSPACE}
BLUELOTUS_ENV_FILE={WORKSPACE}/.env
BLUELOTUS_CONFIG_FILE=config/bluelotus3.yaml
V3_PIPELINE_CONFIG_PATH=config/v3_pipeline_research.yaml
THESIS_REGISTRY_PATH=config/thesis_registry.yaml
OPERATOR_REGISTRY_PATH=config/operator_registry.yaml
MODEL_REGISTRY_PATH=config/model_registry.yaml
LLM_SAFETY_POLICY_PATH=config/llm_safety_policy.yaml
PROMPT_REGISTRY_PATH=config/prompt_registry.yaml
LLM_SCHEMA_DIR=schemas
CHIEF_STRATEGIST_BRIEFING_SCHEMA_PATH=schemas/chief_strategist_briefing.schema.json
OPERATOR_VERDICT_PACK_SCHEMA_PATH=schemas/operator_verdict_pack.schema.json
V3_CYCLE_OUTPUT_DIR=data/v3_cycles
LLM_OUTPUT_DIR=data/llm_outputs
LLM_LOG_DIR=logs
# Research edition: no Ollama required for deterministic clerk
OLLAMA_BASE_URL=http://127.0.0.1:11434
ORDER_ROUTING_ENABLED=false
CIO_ONLY_MANUAL=true
