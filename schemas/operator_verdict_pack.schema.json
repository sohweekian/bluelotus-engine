{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "cycle_id",
    "operator_pack_id",
    "blocked_actions",
    "allowed_actions",
    "manual_execution_required",
    "llm_order_generation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bluelotus_v3_operator_verdict_pack_v1.0"
    },
    "cycle_id": {
      "type": "string"
    },
    "operator_pack_id": {
      "type": "string"
    },
    "blocked_actions": {
      "type": "array"
    },
    "allowed_actions": {
      "type": "array"
    },
    "manual_execution_required": {
      "type": "boolean",
      "const": true
    },
    "llm_order_generation": {
      "type": "boolean",
      "const": false
    }
  }
}
