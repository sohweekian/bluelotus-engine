{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueLotus Benchmark Dashboard",
  "type": "object",
  "required": ["version", "benchmark_id", "strategy_scorecards", "scenario_scorecards", "portfolio_scorecard", "layer_attribution", "one_week_observation_lock", "governance"],
  "properties": {
    "version": {"type": "string"},
    "benchmark_id": {"type": "string"},
    "strategy_scorecards": {"type": "array"},
    "scenario_scorecards": {"type": "array"},
    "portfolio_scorecard": {"type": "object"},
    "layer_attribution": {"type": "array"},
    "one_week_observation_lock": {"type": "object"},
    "governance": {"type": "object"}
  }
}

