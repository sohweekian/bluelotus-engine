{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "cycle_id",
    "recommended_posture",
    "allowed_manual_actions",
    "operator_blocks",
    "manual_execution_required",
    "llm_order_generation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bluelotus_v3_cio_action_menu_v1.0"
    },
    "cycle_id": {
      "type": "string"
    },
    "recommended_posture": {
      "type": "string"
    },
    "allowed_manual_actions": {
      "type": "array"
    },
    "operator_blocks": {
      "type": "array"
    },
    "manual_execution_required": {
      "type": "boolean",
      "const": true
    },
    "llm_order_generation": {
      "type": "boolean",
      "const": false
    }
  }
}
