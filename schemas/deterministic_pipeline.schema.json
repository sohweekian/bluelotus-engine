{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueLotus Deterministic Pipeline",
  "type": "object",
  "required": ["version", "stage_count", "stages", "stage_outputs", "execution_authority", "order_routing_enabled", "orders_generated", "validation"],
  "properties": {
    "version": {"type": "string"},
    "stage_count": {"type": "integer"},
    "stages": {"type": "array"},
    "stage_outputs": {"type": "object"},
    "execution_authority": {"const": "CIO_ONLY_MANUAL"},
    "order_routing_enabled": {"const": false},
    "orders_generated": {"const": 0},
    "validation": {"type": "object"}
  }
}

