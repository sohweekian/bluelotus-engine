{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueLotus Target USD Vector",
  "type": "object",
  "required": ["version", "row_count", "execution_authority", "order_routing_enabled", "system_orders_generated", "rows"],
  "properties": {
    "version": {"type": "string"},
    "row_count": {"type": "integer"},
    "execution_authority": {"const": "CIO_ONLY_MANUAL"},
    "order_routing_enabled": {"const": false},
    "system_orders_generated": {"const": 0},
    "rows": {"type": "array"}
  }
}

