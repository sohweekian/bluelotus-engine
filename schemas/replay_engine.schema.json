{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueLotus Replay Engine",
  "type": "object",
  "required": ["version", "strategies", "scenarios", "benchmark_results", "point_in_time_guard_status", "order_routing_enabled", "orders_generated"],
  "properties": {
    "version": {"type": "string"},
    "strategies": {"type": "array"},
    "scenarios": {"type": "array"},
    "benchmark_results": {"type": "array"},
    "point_in_time_guard_status": {"type": "string"},
    "order_routing_enabled": {"const": false},
    "orders_generated": {"const": 0}
  }
}

