{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "cycle_id",
    "summary",
    "recommended_posture",
    "operator_blocks",
    "agent_consensus",
    "disagreements",
    "cio_attention_items",
    "manual_execution_required",
    "llm_order_generation",
    "created_at_sgt"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bluelotus_v3_chief_strategist_briefing_v1.0"
    },
    "cycle_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "recommended_posture": {
      "type": "string",
      "enum": [
        "WAIT",
        "HOLD",
        "REVIEW",
        "REDUCE_RISK_REVIEW",
        "RAISE_CASH_REVIEW",
        "HEDGE_REVIEW",
        "MANUAL_BUY_REVIEW",
        "MANUAL_SELL_REVIEW"
      ]
    },
    "operator_blocks": {
      "type": "array"
    },
    "agent_consensus": {
      "type": "array"
    },
    "disagreements": {
      "type": "array"
    },
    "cio_attention_items": {
      "type": "array"
    },
    "manual_execution_required": {
      "type": "boolean",
      "const": true
    },
    "llm_order_generation": {
      "type": "boolean",
      "const": false
    },
    "created_at_sgt": {
      "type": "string"
    }
  }
}
