{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueLotus Risk Overlay",
  "type": "object",
  "required": ["version", "portfolio", "ticker_outputs", "risk_overlay_status", "execution_authority", "order_routing_enabled", "system_orders_generated"],
  "properties": {
    "version": {"type": "string"},
    "portfolio": {"type": "object"},
    "ticker_outputs": {"type": "array"},
    "risk_overlay_status": {"type": "string"},
    "execution_authority": {"const": "CIO_ONLY_MANUAL"},
    "order_routing_enabled": {"const": false},
    "system_orders_generated": {"const": 0}
  }
}

