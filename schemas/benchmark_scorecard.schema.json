{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueLotus Benchmark Scorecard",
  "type": "object",
  "required": ["rank", "strategy_id", "avg_return_proxy", "avg_drawdown_proxy", "avg_sharpe_proxy"],
  "properties": {
    "rank": {"type": "integer"},
    "strategy_id": {"type": "string"},
    "avg_return_proxy": {"type": "number"},
    "avg_drawdown_proxy": {"type": "number"},
    "avg_sharpe_proxy": {"type": "number"}
  }
}

